{
  "permissions": {
    "allow": [
      "Bash(export PATH=\"$PATH:/c/Users/andre/AppData/Local/Microsoft/WinGet/Links:/c/Windows/System32/WindowsPowerShell/v1.0\")",
      "Bash(powershell.exe -Command \"Remove-Item ''''f:/Programacion/qn-arq-app/public/hero-frames/*.jpg''''\")",
      "Bash(ffmpeg -i \"f:/Programacion/qn-arq-app/public/hero-video/newhero.mp4\" -vf \"fps=30\" -q:v 3 \"f:/Programacion/qn-arq-app/public/hero-frames/frame_%04d.jpg\")",
      "Bash(export PATH=\"$PATH:/c/Users/andre/AppData/Local/Microsoft/WinGet/Links:/c/Windows/System32/WindowsPowerShell/v1.0:/usr/bin\")",
      "Bash(powershell.exe -Command \"Remove-Item ''f:/Programacion/qn-arq-app/public/hero-frames/*.jpg''\")",
      "Bash(export PATH=\"$PATH:/c/Users/andre/AppData/Local/Microsoft/WinGet/Links:/usr/bin\")"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  }
}
